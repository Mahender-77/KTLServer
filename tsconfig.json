{
  "include": ["src"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Project Structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Strictness */
    "strict": true,

    /* Node Compatibility */
    "esModuleInterop": true,
    "types": ["node"],

    /* Quality of Life */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
