# =============================================================================
# KTL API — copy to `.env` and adjust per environment (dev / staging / prod).
# Never commit real `.env` files.
# =============================================================================

NODE_ENV=development

# HTTP server
PORT=5000
# Bind address (default 0.0.0.0 = all interfaces). Use 127.0.0.1 for local-only.
# HOST=0.0.0.0

# MongoDB (required)
MONGO_URI=mongodb://127.0.0.1:27017/ktl_dev

# JWT — min 16 characters each; use strong random values in production
JWT_SECRET=change-me-min-16-chars-dev-only
JWT_REFRESH_SECRET=change-me-min-16-chars-dev-only

# Platform super-admins (comma-separated emails). Matched users get `isSuperAdmin` on server startup.
# SUPER_ADMIN_EMAILS=ops@example.com

# Browser CORS origins (comma-separated). Set for admin/Vite + Expo web during local dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081

# Cloudinary (product images). All three required for uploads to work.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limits (optional; defaults are safe — see src/config/rateLimit.ts)
# RATE_LIMIT_GENERAL_MAX=100
# RATE_LIMIT_GENERAL_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=5
# RATE_LIMIT_AUTH_WINDOW_MS=900000
